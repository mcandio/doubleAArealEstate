---
const year = new Date().getFullYear();
---

<footer id="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="logo-mark">AA</span>
      <span class="logo-name">dobleAArealstate</span>
    </div>

    <div class="footer-rule" aria-hidden="true"></div>

    <address class="footer-address">
      <span>1198 SW 158th Way</span>
      <span>Pembroke Pines, FL 33027</span>
      <span>operated by Allavigojuva LLC</span>
      <a href="tel:+19544440818">+1 954 444 0818</a>
    </address>

    <div class="footer-rule" aria-hidden="true"></div>

    <p class="footer-copy">
      &copy; {year} dobleAArealstate &middot; Allavigojuva LLC &middot; All rights reserved
    </p>
  </div>
</footer>

<style>
  #site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 4rem 2rem 2.5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .footer-brand {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .logo-mark {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .logo-name {
    font-size: 0.68rem;
    font-weight: 300;
    color: var(--color-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .footer-rule {
    width: 36px;
    height: 1px;
    background: var(--color-border);
  }

  .footer-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--color-muted);
    line-height: 1.75;
  }

  .footer-address a {
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 0.2rem;
    transition: opacity 0.2s;
  }

  .footer-address a:hover {
    opacity: 0.75;
  }

  .footer-copy {
    font-size: 0.68rem;
    color: var(--color-border);
    letter-spacing: 0.06em;
  }
</style>
