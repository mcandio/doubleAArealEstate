---
---

<section id="cta" aria-label="Call to action">
  <div class="cta-inner">
    <div class="cta-rule" aria-hidden="true"></div>
    <p class="eyebrow">Ready to move forward?</p>
    <h2 class="headline">
      Find Your<br /><em>Dream Property</em>
    </h2>
    <p class="body-text">
      Whether you're buying, selling, or investing —<br class="br-desk" />
      our team knows South Florida inside out.
    </p>
    <a href="#contact" class="btn-primary">Contact Us Today</a>
  </div>
</section>

<style>
  #cta {
    background:
      radial-gradient(ellipse at 50% 0%, #1e1606 0%, transparent 65%),
      #0e0e0b;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 7rem 2rem;
    text-align: center;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .cta-rule {
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, transparent, var(--color-gold));
    margin-bottom: 2rem;
    opacity: 0.6;
  }

  .eyebrow {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
  }

  .headline {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.5vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 1.75rem;
  }

  .headline em {
    color: var(--color-gold);
    font-style: italic;
  }

  .body-text {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-muted);
    line-height: 1.85;
    margin-bottom: 2.75rem;
  }

  .btn-primary {
    display: inline-block;
    text-decoration: none;
    padding: 0.9rem 2.75rem;
    background: var(--color-gold);
    color: var(--color-bg);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: background 0.22s, transform 0.22s;
  }

  .btn-primary:hover {
    background: #d4b47a;
    transform: translateY(-2px);
  }

  .br-desk { display: inline; }

  @media (max-width: 640px) {
    #cta { padding: 5rem 1.25rem; }
    .br-desk { display: none; }
  }
</style>
